<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:orientation="vertical"
    android:padding="20dp">
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="30dp">
        <ImageView
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:src="@drawable/logo"
            android:scaleType="fitCenter" />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="java's VLAN"
            android:textColor="#FFFFFF"
            android:textSize="28sp"
            android:textStyle="bold"
            android:layout_marginLeft="15dp" />
    </LinearLayout>
    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Status: DISCONNECTED"
        android:textColor="#FF0000"
        android:textSize="16sp"
        android:textStyle="bold"
        android:padding="10dp"
        android:background="#121212"
        android:layout_marginBottom="20dp" />
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="VLAN Relay Server Address / Port:"
        android:textColor="#FFFFFF"
        android:textSize="12sp" />
    <EditText
        android:id="@+id/etServerIp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#1A1A1A"
        android:textColor="#FFFFFF"
        android:padding="12dp"
        android:layout_marginBottom="15dp"
        android:text="your-playit-subdomain.playit.gg"
        android:inputType="text" />
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Network Name:"
        android:textColor="#FFFFFF"
        android:textSize="12sp" />
    <EditText
        android:id="@+id/etNetworkName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#1A1A1A"
        android:textColor="#FFFFFF"
        android:padding="12dp"
        android:layout_marginBottom="15dp"
        android:hint="e.g. LanParty"
        android:textColorHint="#555555"
        android:inputType="text" />
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Password:"
        android:textColor="#FFFFFF"
        android:textSize="12sp" />
    <EditText
        android:id="@+id/etPassword"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#1A1A1A"
        android:textColor="#FFFFFF"
        android:padding="12dp"
        android:layout_marginBottom="25dp"
        android:hint="Password"
        android:textColorHint="#555555"
        android:inputType="textPassword" />
    <Button
        android:id="@+id/btnCreateNetwork"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:backgroundTint="#FFFFFF"
        android:textColor="#000000"
        android:text="Create Network"
        android:textStyle="bold"
        android:layout_marginBottom="10dp" />
    <Button
        android:id="@+id/btnConnectNetwork"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:backgroundTint="#333333"
        android:textColor="#FFFFFF"
        android:text="Connect To Network"
        android:textStyle="bold"
        android:layout_marginBottom="10dp" />
    <Button
        android:id="@+id/btnToggleVpn"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:backgroundTint="#FF0000"
        android:textColor="#FFFFFF"
        android:text="Turn On"
        android:textStyle="bold" />
</LinearLayout>
